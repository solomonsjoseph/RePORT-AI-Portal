# ============================================================================
# RePORT AI Portal — Environment Variables Example
# ============================================================================
# Copy this file to `.env` and set only the values you need for your local or
# deployed runtime.
#
# Precedence:
#   environment variables > config.py defaults > config/config.yaml defaults
#
# SECURITY:
#   - Never commit a filled `.env` file.
#   - Never put real secrets in `.env.example`.
# ============================================================================

# ============================================================================
# Study / Runtime Overrides
# ============================================================================
# STUDY_NAME=Indo-VAP

# ============================================================================
# Logging
# ============================================================================
# LOG_DIR=.logs
# LOG_LEVEL=INFO
# LOG_VERBOSE=false
# LOG_FORMAT=text

# ============================================================================
# PHI-safety flags (see docs/irb_dossier/ for the IRB-grade benchmark)
# ============================================================================

# Staging root — when set to a truthy value AND /dev/shm is writable, staging
# for the extraction leg redirects to /dev/shm/report_ai_portal/{STUDY}/ so
# raw extracted rows never touch physical disk on the extraction host.
# Linux only; no-op on macOS / Windows (gracefully falls back to tmp/).
# REPORTALIN_TMPFS_STAGING=0

# PDF extraction PHI-safety gate — default is DENY.
# External-API PDF extraction (Anthropic / Google Gemini) is a network
# egress of raw PDF bytes. data/raw/{STUDY}/annotated_pdfs/ is treated as
# PHI-bearing by default. Set this to "1" ONLY if the operator has
# verified the source PDFs are PHI-free (blank CRF templates, study
# protocol, MOP, annotation-only pages). This is your signed assertion
# for the IRB.
# REPORTALIN_PDF_PHI_FREE=0

# ============================================================================
# Notes
# ============================================================================
# - Processed study artifacts belong under `output/{STUDY_NAME}/...`, not `data/`.
# - Use config/config.yaml for non-secret project defaults.
# - Use environment variables for secrets and deploy-specific overrides.
# - PHI HMAC key lives at ~/.config/report_ai_portal/phi_key (mode 0600)
#   outside this repo — NEVER check it in. Bootstrap with:
#       python -m scripts.security.phi_scrub bootstrap-key
# ============================================================================
