*.db
*.sqlite
*.sqlite3
*.db-journal

# ============================================================================
# 14. Canonical Data Zones (CRITICAL - PHI/PII protection)
# ============================================================================
# Raw Vault — contains PHI, never expose to LLM runtime, only for secure storage
# Ignore all raw-study contents under data/raw/ for every study.
data/raw/**
# Keep a placeholder only if the repo uses one.
!data/raw/.gitkeep

# Study-scoped processed artifacts (all under output/{STUDY}/)
# Note: output/ itself is already ignored below — these entries are
# explicit for clarity and to survive selective .gitignore edits.
#
#   output/{STUDY}/trio_bundle/ — PHI-free LLM read zone
#   output/{STUDY}/audit/       — counts-only IRB evidence
#   output/{STUDY}/agent/       — session state
#   output/session_tmp/         — ephemeral session data (shared)

# ============================================================================
# 15. Project-Specific
# ============================================================================
# Excel temporary files
data/raw/**/~$*.xlsx
~$*.xlsx

# Output directory — raw extractions, never commit.
# All subtrees — trio_bundle/, audit/, agent/ — stay out of git by design.
output/
output*/**

# Large data files (uncomment if needed)
# data/raw/dataset/
# data/raw/Annotated_PDFs/

# Vision and Implementation plan files
docs/.vision/
docs/.vision/**

# Documentation Policy: NO .md files except README.md, docs/*.md,
# AGENTS.md (agent-facing instructions, tracked convention), docs/agents/*.md
# (agent skill configuration), and the IRB dossier under docs/irb_dossier/
# (regulatory evidence package). All long-form non-regulatory documentation
# still goes in docs/sphinx/*.rst.
*.md
!README.md
!docs/*.md
!AGENTS.md
!docs/agents/*.md
!docs/irb_dossier/*.md

# GitHub instructions (local copilot config — not tracked)
.github/instructions/
.github/prompts/

# Temporary documentation files
FIXES.md
AUDIT.md
VERIFICATION.md
STATUS.md
CHANGES.md
NOTES.md
*_VERIFICATION*.md
*_AUDIT*.md
*_REPORT*.md
*_SUMMARY*.md
!docs/irb_dossier/*.md

# AI related artifacts
.claude/

# NON PHI/PII data artifacts (uncomment if needed, but be cautious about PHI/PII exposure
!data/raw/Indo-VAP/**

# Playwright browser artifacts (uncomment if using Playwright for testing)
.playwright*/

# ============================================================================
# 16. Third-Party AI-Tool Vendor Configs (auto-generated, not RePORTaLiN state)
# ============================================================================
# Each of these is auto-created by a vendor AI tool dropped into the repo.
# None are required for RePORTaLiN-RAG to build, lint, test, or run.
.agent/
.codebuddy/
.codex/
.continue/
.cursor/
.gemini/
.kiro/
.opencode/
.qoder/
.roo/
.trae/
.windsurf/

# ============================================================================
# 17. Local Working Backups
# ============================================================================
# Ad-hoc snapshot folder used for local before/after backups. Never committed.
archives/

# ============================================================================
# 18. Removed Directories (kept gitignored to prevent reintroduction)
# ============================================================================
# Deprecated legacy PHI code — superseded by scripts/security/
scripts/archive/
# Development-only utilities (Playwright, snapshots, live session)
scripts/ai_assistant/dev/
# Internal planning workflow artifacts — design docs are in docs/sphinx/
docs/plan/
# Internal audit / review notes (kept locally, not committed)
audit/
# Development prompt templates
docs/prompts/
# Tool-generated planning artifacts
docs/superpowers/
# Test output and snapshot placeholders
test-results/
# NOTE: ``data/snapshots/{STUDY}/`` is intentionally trackable. It holds the
# human-reviewed cleaned trio bundle baseline used to repair a broken live
# ``output/{STUDY}/trio_bundle/``. Raw PHI remains ignored under ``data/raw/``.

# Test fixture exceptions — synthetic mini-fixtures under tests/fixtures/sot_gap
# contain no real data and must be tracked even though their paths match the
# broad output/ and tmp/ ignore patterns above.
!tests/fixtures/sot_gap/
!tests/fixtures/sot_gap/**
