# ============================================================================
# 10. De-identification & PHI/PII (CRITICAL - DO NOT COMMIT)
# ============================================================================
# Mapping files (contain PHI/PII → pseudonym relationships)
*_mappings.json
*_mappings.json.enc
*_deidentification_key.key
*_deidentification_audit.json
output/deidentified/mappings/

# Original dataset directories (may contain PHI/PII)
output/datasets/

# Any files marked as containing PHI/PII
*_phi.json
*_pii.json
*_sensitive.*

# PHI audit artifacts (legacy — retained for safety)
phi_report.json
phi_summary.json
*.audit.json
phi_report_*.json

